THERMALFORGE_ENVIRONMENT=development
THERMALFORGE_DATABASE_URL=sqlite+aiosqlite:///./.data/thermalforge.db
THERMALFORGE_AUTO_CREATE_SCHEMA=true
THERMALFORGE_REDIS_URL=redis://127.0.0.1:6379/0
THERMALFORGE_QUEUE_ENABLED=false
THERMALFORGE_ARTIFACT_BACKEND=local
THERMALFORGE_ARTIFACT_ROOT=.data/artifacts
THERMALFORGE_UPLOAD_TEMP_ROOT=.data/uploads
THERMALFORGE_MODEL_ASSET_ROOT=../frontend/public/models
THERMALFORGE_WHOLE_MODEL_FILENAME=foc-robot-arm.glb
THERMALFORGE_SEGMENTED_MODEL_FILENAME=foc-robot-arm-bang.glb
THERMALFORGE_HYPER3D_MODEL_FILENAME=hyper3d-robot-arm.glb
THERMALFORGE_MAX_UPLOAD_BYTES=20971520
THERMALFORGE_MAX_ARCHIVE_ENTRIES=2000
THERMALFORGE_MAX_ARCHIVE_UNCOMPRESSED_BYTES=104857600
THERMALFORGE_MAX_IMAGE_PIXELS=50000000
THERMALFORGE_LLM_PROVIDER=fixture
THERMALFORGE_ANTHROPIC_API_KEY=
THERMALFORGE_ANTHROPIC_MODEL=claude-opus-4-8
THERMALFORGE_OPENAI_API_KEY=
THERMALFORGE_OPENAI_BASE_URL=https://www.micuapi.ai/v1
THERMALFORGE_OPENAI_MODEL=gpt-5.6-sol
THERMALFORGE_IMAGE_PROVIDER=fixture
THERMALFORGE_OPENAI_IMAGE_MODEL=gpt-image-2
THERMALFORGE_IMAGE_TIMEOUT_SECONDS=180
THERMALFORGE_IMAGE_MAX_RETRIES=2
THERMALFORGE_LLM_TIMEOUT_SECONDS=120
THERMALFORGE_LLM_MAX_RETRIES=2
THERMALFORGE_LLM_MAX_TOKENS=16000
THERMALFORGE_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# S3-compatible production storage (MinIO in Docker Compose)
THERMALFORGE_S3_ENDPOINT_URL=http://127.0.0.1:9000
THERMALFORGE_S3_BUCKET=thermalforge-artifacts
THERMALFORGE_S3_ACCESS_KEY=change-me
THERMALFORGE_S3_SECRET_KEY=change-me

# PostgreSQL deployment example:
# THERMALFORGE_DATABASE_URL=postgresql+asyncpg://thermalforge:change-me@postgres:5432/thermalforge
