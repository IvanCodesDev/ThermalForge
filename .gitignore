# Dependencies and generated output
**/node_modules/
**/dist/
**/dist-ssr/
**/coverage/
**/*.tsbuildinfo

# Runtime secrets and local environment
**/.env
**/.env.*
!**/.env.example
**/*.local

# Logs and caches
**/logs/
**/*.log
**/.cache/
**/.tmp/

# Personal IDE and operating-system state
.cursor/
.superpowers/
.vscode/
**/.idea/
**/.DS_Store
**/Thumbs.db

# Root-level package metadata created without a workspace manifest
/package-lock.json

# Local design-reference project; not part of the published application
/shiligongfang/

# Python bytecode and caches
**/__pycache__/
**/*.pyc
**/*.pyo

# Frontend (separate build pipeline)
/frontend/

# AI assistant working state
.workbuddy/

# Generated outputs and vector stores
/outputs/
/vectors/

# Local databases
/data/*.db

# Runtime / test-output data directories
/data/connector_e2e/
/data/connector_live/
/data/loop_output/
/data/loop_spaceclaim/
/data/sc_test/
/data/spaceclaim_candidates/
/data/spaceclaim_live/
/data/exploded_view_cache/

# Stray runtime artifacts
/data/connector_live_result.json
/data/leaf_optimizer_demo.json
/1.4.0

# HPC job scripts with machine-specific paths
/data/diag_journal
/data/diag_sub.sh
/data/share0711_journal
/data/share0711_sub.sh
/data/share0711_tui_journal
